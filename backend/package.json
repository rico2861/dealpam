{
  "name": "dealpam-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "dev": "dotenv -e .env.local -- nest start --watch",
    "dev:setup": "dotenv -e .env.local -- prisma migrate dev --schema=prisma/schema.sqlite.prisma --name init",
    "dev:generate": "dotenv -e .env.local -- prisma generate --schema=prisma/schema.sqlite.prisma",
    "dev:studio": "dotenv -e .env.local -- prisma studio --schema=prisma/schema.sqlite.prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^5.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.7",
    "@types/passport-jwt": "^3.0.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "helmet": "^7.0.0",
    "multer": "^2.2.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.17.2",
    "rxjs": "^7.8.0",
    "sharp": "^0.35.2",
    "socket.io": "^4.6.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/jest": "^30.0.0",
    "chokidar": "^5.0.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.0"
  },
  "overrides": {
    "multer": "^2.2.0",
    "js-yaml": "^4.1.0"
  }
}
