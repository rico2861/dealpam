generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url       = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────














// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String?   @unique
  phone                String?   @unique
  passwordHash         String    @map("password_hash")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  avatar               String?
  role                 String      @default("CUSTOMER")
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  isActive             Boolean   @default(true) @map("is_active")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  tokenVersion         Int       @default(0) @map("token_version")
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  lastLoginAt          DateTime? @map("last_login_at")
  lastLoginIp          String?   @map("last_login_ip")

  // Geo
  city                 String?
  department           String?

  // Away message (for sellers)
  awayMessageEnabled   Boolean   @default(false) @map("away_message_enabled")
  awayMessage          String?   @map("away_message")

  // E2E encryption
  publicKey            String?   @map("public_key")

  // Staff-specific metadata (JSON): { partnershipPercent, responsibilities, notes }
  staffMeta            String?   @map("staff_meta")

  refreshTokens        RefreshToken[]
  addresses            Address[]
  orders               Order[]
  wishlistItems        WishlistItem[]
  cart                 Cart?
  reviews              Review[]
  complaints           Complaint[]
  notifications        Notification[]
  seller               Seller?
  auditLogs            AuditLog[]
  sentMessages              Message[]           @relation("MessageSender")
  conversations             ConversationUser[]
  assignedConversations     Conversation[]      @relation("ConvAssignedAgent")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([department])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           String  @default("PENDING")
  businessType     String? @map("business_type")
  businessCity     String?       @map("business_city")
  businessDept     String?       @map("business_dept")
  businessAddress  String?       @map("business_address")
  nif              String?       @unique
  idDocumentUrl    String?       @map("id_document_url")
  businessDocUrl   String?       @map("business_doc_url")
  rejectionReason  String?       @map("rejection_reason")
  approvedBy       String?       @map("approved_by")
  approvedAt       DateTime?     @map("approved_at")
  stores           Store[]
  subscriptions    SellerSubscription[]
  documents        BusinessDocument[]
  adCampaigns      AdCampaign[]
  wallet           SellerWallet?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([businessDept])
  @@map("sellers")
}

model BusinessDocument {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type      String   // "ID", "BUSINESS_REGISTRATION", "TAX", "OTHER"
  url       String
  publicId  String   @map("public_id")
  fileName  String   @map("file_name")
  isValid   Boolean? @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@map("business_documents")
}

model Store {
  id           String    @id @default(uuid())
  storeCode    String?   @unique @map("store_code") // SHOP-XXXX
  sellerId     String    @map("seller_id")
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String    @unique
  slug         String    @unique
  isPrimary    Boolean   @default(false) @map("is_primary")
  description  String?
  logoUrl      String?   @map("logo_url")
  bannerUrl    String?   @map("banner_url")
  address      String?
  city         String?
  department   String?
  phone        String?
  email        String?
  whatsapp     String?
  // Méthodes de paiement que le vendeur accepte (MONCASH, NATCASH, CASH, BANK_TRANSFER, OTHER)
  acceptedPaymentMethods String @default("[]") @map("accepted_payment_methods")
  // Numéro MonCash du vendeur (pour que le client sache où payer)
  moncashPhone String?  @map("moncash_phone")
  // Points de retrait : [{name, address, city, dept, phone, hours}]
  pickupPoints String?    @map("pickup_points")
  // Zones de livraison : [{dept, priceHTG, estimatedDays}]
  deliveryZones String?   @map("delivery_zones")
  // Horaires : {mon:{open,close,closed},tue:…,wed:…,thu:…,fri:…,sat:…,sun:…}
  schedule      String?   @map("schedule")
  avgRating        Float     @default(0) @map("avg_rating")
  totalReviews     Int       @default(0) @map("total_reviews")
  totalSales       Int       @default(0) @map("total_sales")
  isVerified       Boolean   @default(false) @map("is_verified")
  isActive         Boolean   @default(true) @map("is_active")
  isPlatformStore  Boolean   @default(false) @map("is_platform_store")
  badges           String  @default("[]")
  reputationScore  Float     @default(100) @map("reputation_score")
  avgResponseTime  Int?      @map("avg_response_time") // minutes
  lastBadgeUpdate  DateTime? @map("last_badge_update")
  products     Product[]
  reviews      Review[]
  orders       Order[]
  appointments Appointment[]
  adCampaigns  AdCampaign[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([storeCode])
  @@index([department])
  @@map("stores")
}

model SubscriptionPlan {
  id                String           @id @default(uuid())
  tier              String @unique
  name              String
  priceHTG          Float          @map("price_htg")
  maxProducts       Int?             @map("max_products")
  maxImages         Int              @default(5) @map("max_images")
  maxStores         Int              @default(1) @map("max_stores")
  hasVerifiedBadge  Boolean          @default(false) @map("has_verified_badge")
  hasEliteBadge     Boolean          @default(false) @map("has_elite_badge")
  hasPrioritySearch Boolean          @default(false) @map("has_priority_search")
  hasHomepageAd     Boolean          @default(false) @map("has_homepage_ad")
  hasAdvancedStats  Boolean          @default(false) @map("has_advanced_stats")
  hasAutoSponsored  Boolean          @default(false) @map("has_auto_sponsored")
  hasKeywordTargeting Boolean        @default(false) @map("has_keyword_targeting")
  description       String?
  isActive          Boolean          @default(true) @map("is_active")
  isPopular         Boolean          @default(false) @map("is_popular")
  originalPriceHTG  Float?           @map("original_price_htg")
  maxPromoProducts    Int            @default(0) @map("max_promo_products")
  maxCarouselProducts Int            @default(0) @map("max_carousel_products")
  // % de réduction si le vendeur paie pour 1 an d'un coup (configurable par l'admin)
  annualDiscountPercent Int          @default(25) @map("annual_discount_percent")
  subscriptions     SellerSubscription[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model SellerSubscription {
  id        String           @id @default(uuid())
  sellerId  String           @map("seller_id")
  seller    Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  planId    String           @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  isActive  Boolean          @default(true) @map("is_active")
  autoRenew Boolean          @default(true) @map("auto_renew")
  billingCycle String        @default("MONTHLY") @map("billing_cycle") // MONTHLY | ANNUAL
  isTrial   Boolean          @default(false) @map("is_trial")
  payment   Payment?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([isActive])
  @@index([endDate])
  @@map("seller_subscriptions")
}

model TrialUsage {
  id       String   @id @default(uuid())
  sellerId String   @map("seller_id")
  phone    String?
  email    String?
  nif      String?
  usedAt   DateTime @default(now()) @map("used_at")

  @@index([phone])
  @@index([email])
  @@index([nif])
  @@map("trial_usages")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  imageUrl  String?    @map("image_url")
  icon      String?
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("brands")
}

model Product {
  id              String      @id @default(uuid())
  storeId         String      @map("store_id")
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId      String      @map("category_id")
  category        Category    @relation(fields: [categoryId], references: [id])
  brandId         String?     @map("brand_id")
  brand           Brand?      @relation(fields: [brandId], references: [id])
  name            String
  slug            String      @unique
  subtitle        String?
  description     String
  sku             String?     @unique
  productType     String @default("PHYSICAL") @map("product_type")

  // Pricing
  price           Float
  salePrice       Float?    @map("sale_price")
  stock           Int         @default(0)
  sizes           String  @default("[]")
  colors          String  @default("[]")

  // Geo / Delivery
  address         String?                 // Full address (for services/RE)
  city            String?
  department      String?    // Département haïtien
  hasDelivery     Boolean    @default(false) @map("has_delivery")
  deliveryPriceHTG Float?  @map("delivery_price_htg")
  deliveryDepts   String   @default("[]") @map("delivery_depts")  // List of departments where delivery is available

  // Vehicle / Rental specific
  year            Int?
  mileage         Int?
  condition       String?    // "new", "used", "refurbished"
  requiresAppointment Boolean @default(false) @map("requires_appointment")

  // Status & flags
  status          String @default("DRAFT")
  isFeatured      Boolean   @default(false) @map("is_featured")
  isSponsored     Boolean   @default(false) @map("is_sponsored")
  avgRating       Float     @default(0) @map("avg_rating")
  totalReviews    Int       @default(0) @map("total_reviews")
  totalSold       Int       @default(0) @map("total_sold")
  viewCount       Int       @default(0) @map("view_count")
  rejectionReason String?   @map("rejection_reason")

  // Category-specific attributes stored as JSON (phone: brand/model/storage/ram; clothing: material/gender; etc.)
  attributes      String?         @map("attributes")
  // Service / Immobilier / Freelance extra config (JSON)
  serviceConfig   String?         @map("service_config")
  // Price unit label: "HTG/heure", "HTG/séance", "HTG/m²", "HTG/projet", "HTG/nuit"
  priceUnit       String?         @map("price_unit")

  images          ProductImage[]
  variants        ProductVariant[]
  priceHistory    PriceHistory[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  appointments    Appointment[]
  adCampaigns     AdCampaign[]
  flashSaleItems  FlashSaleItem[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([department])
  @@index([hasDelivery])
  @@index([productType])
  @@index([isFeatured])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  urlFull   String   @map("url_full")     // 800px WebP
  urlMedium String   @map("url_medium")   // 600px WebP
  urlThumb  String   @map("url_thumb")    // 300px WebP
  publicId  String   @map("public_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color         String?
  colorHex      String?  @map("color_hex")
  size          String?
  stock         Int      @default(0)
  priceOverride Float? @map("price_override")
  imageUrl      String?  @map("image_url")
  imagePublicId String?  @map("image_public_id")
  sku           String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_variants")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  size      String?
  color     String?

  @@unique([cartId, productId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  fullName   String   @map("full_name")
  phone      String
  line1      String
  city       String
  department String
  isDefault  Boolean  @default(false) @map("is_default")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addresses")
}

model Order {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  user           User        @relation(fields: [userId], references: [id])
  storeId        String      @map("store_id")
  store          Store       @relation(fields: [storeId], references: [id])
  addressId      String?     @map("address_id")
  address        Address?    @relation(fields: [addressId], references: [id])
  status         String @default("PENDING")
  subtotalHTG    Float     @map("subtotal_htg")
  shippingHTG    Float     @default(0) @map("shipping_htg")
  totalHTG       Float     @map("total_htg")
  notes                String?
  trackingNumber       String?  @map("tracking_number")
  // Livraison : DELIVERY (adresse) | PICKUP (retrait boutique) | CONTACT (direct contact)
  deliveryType         String?  @default("DELIVERY") @map("delivery_type")
  pickupPointName      String?  @map("pickup_point_name")
  pickupPointAddress   String?  @map("pickup_point_address")
  // Méthode de paiement choisie par le client (parmi celles du vendeur)
  chosenPaymentMethod  String?  @map("chosen_payment_method")
  // Référence de transaction soumise par le client (MonCash/NatCash txId)
  paymentTxRef         String?  @map("payment_tx_ref")
  paymentTxStatus      String?  @default("PENDING") @map("payment_tx_status")
  paymentTxNote        String?  @map("payment_tx_note")
  paymentVerifiedBy    String?  @map("payment_verified_by")
  paymentVerifiedAt    DateTime? @map("payment_verified_at")
  items          OrderItem[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([paymentTxStatus])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name")
  imageUrl    String? @map("image_url")
  quantity    Int
  unitPrice   Float @map("unit_price")
  subtotal    Float

  @@map("order_items")
}

model Payment {
  id             String              @id @default(uuid())
  // Payments = vendeurs seulement (abonnements + pub). Pas de paiement client sur plateforme.
  subscriptionId String?             @unique @map("subscription_id")
  subscription   SellerSubscription? @relation(fields: [subscriptionId], references: [id])
  adCampaign     AdCampaign?
  method         String
  status         String       @default("PENDING")
  amountHTG            Float             @map("amount_htg")

  // Référence interne plateforme (UUID envoyé à MonCash comme orderId)
  transactionId        String?             @unique @map("transaction_id")
  // moncash_order_id retourné par l'API MonCash lors de l'initiation
  moncashOrderId       String?             @unique @map("moncash_order_id")
  // transaction_id final confirmé par MonCash (webhook / confirm endpoint)
  moncashTransactionId String?             @unique @map("moncash_transaction_id")

  gatewayData          String?               @map("gateway_data")
  paidAt               DateTime?           @map("paid_at")
  failureReason        String?             @map("failure_reason")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([moncashOrderId])
  @@index([status])
  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  productId  String?  @map("product_id")
  product    Product? @relation(fields: [productId], references: [id])
  storeId    String?  @map("store_id")
  store      Store?   @relation(fields: [storeId], references: [id])
  rating     Int
  comment    String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model Complaint {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  type        String
  status      String @default("OPEN")
  subject     String
  description String
  orderId     String?         @map("order_id")
  sellerId    String?         @map("seller_id")
  productId   String?         @map("product_id")
  adminNote   String?         @map("admin_note")
  resolvedAt  DateTime?       @map("resolved_at")
  resolvedBy  String?         @map("resolved_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@map("complaints")
}

model Appointment {
  id          String            @id @default(uuid())
  userId      String?           @map("user_id")   // null for guest bookings
  productId   String            @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  storeId     String            @map("store_id")
  store       Store             @relation(fields: [storeId], references: [id])
  status      String @default("PENDING")
  scheduledAt DateTime          @map("scheduled_at")
  note        String?
  sellerNote  String?           @map("seller_note")
  // Guest booking info (client non connecté)
  clientName  String?           @map("client_name")
  clientPhone String?           @map("client_phone")
  clientEmail String?           @map("client_email")
  // Service sub-type (ex: "Coupe femme", "Détartrage", "Logo design")
  serviceType String?           @map("service_type")
  // Duration in minutes
  duration    Int?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@map("appointments")
}

model Conversation {
  id              String             @id @default(uuid())
  participants    ConversationUser[]
  messages        Message[]
  lastMessage     String?            @map("last_message")
  lastMessageAt   DateTime?          @map("last_message_at")
  isSupport       Boolean            @default(false) @map("is_support")
  topic           String?
  status          String             @default("OPEN")  // OPEN | RESOLVED | CLOSED
  ticketNumber    String?            @unique @map("ticket_number")
  assignedAgentId String?            @map("assigned_agent_id")
  assignedAgent   User?              @relation("ConvAssignedAgent", fields: [assignedAgentId], references: [id])
  closedAt        DateTime?          @map("closed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([isSupport])
  @@index([status])
  @@map("conversations")
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unreadCount    Int          @default(0) @map("unread_count")
  lastSeenAt     DateTime?    @map("last_seen_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_users")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String      @map("sender_id")
  sender         User        @relation("MessageSender", fields: [senderId], references: [id])
  type           String @default("TEXT")
  content        String
  mediaUrl       String?     @map("media_url")
  isRead         Boolean     @default(false) @map("is_read")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValues String?    @map("old_values")
  newValues String?    @map("new_values")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

model PriceHistory {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Float
  salePrice   Float? @map("sale_price")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([productId, recordedAt])
  @@map("price_history")
}

model UserEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  sessionId   String   @map("session_id")
  eventType   String   @map("event_type") // VIEW, LIKE, UNLIKE, SEARCH, CLICK, ADD_CART, PURCHASE
  productId   String?  @map("product_id")
  categorySlug String? @map("category_slug")
  searchQuery String?  @map("search_query")
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
  @@map("user_events")
}

// ─── Ad Campaign (Boost Produit — style Meta Ads) ─────────────────────────────



model AdCampaign {
  id             String      @id @default(uuid())
  sellerId       String      @map("seller_id")
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId      String?     @map("product_id")
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  storeId        String?     @map("store_id")
  store          Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)

  // Paramètres de la campagne
  name           String
  objective      String @default("TRAFFIC")
  status         String    @default("DRAFT")

  // Budget
  totalBudget    Float     @map("total_budget")  // HTG total
  dailyBudget    Float?    @map("daily_budget")
  spent          Float     @default(0)           // HTG dépensé

  // Durée
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")

  // Ciblage
  targetGenders    String  @default("[]") @map("target_genders")   // ["MALE","FEMALE","ALL"]
  targetAgeMin     Int?      @map("target_age_min")
  targetAgeMax     Int?      @map("target_age_max")
  targetDepts      String  @default("[]") @map("target_depts")     // Départements haïtiens
  targetCategories String  @default("[]") @map("target_categories")

  // Statistiques
  impressions    Int         @default(0)
  clicks         Int         @default(0)
  conversions    Int         @default(0)

  // Paiement
  paymentId      String?     @unique @map("payment_id")
  payment        Payment?    @relation(fields: [paymentId], references: [id])

  // Admin
  reviewNote     String?     @map("review_note")
  reviewedBy     String?     @map("reviewed_by")
  reviewedAt     DateTime?   @map("reviewed_at")

  events         AdEvent[]

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([productId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("ad_campaigns")
}

model AdEvent {
  id          String     @id @default(uuid())
  campaignId  String     @map("campaign_id")
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        String     // "IMPRESSION" | "CLICK" | "CONVERSION"
  userId      String?    @map("user_id")  // null = visiteur anonyme
  userDept    String?    @map("user_dept")
  cost        Float    @default(0)  // HTG débité
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([campaignId])
  @@index([type])
  @@index([createdAt])
  @@map("ad_events")
}

// ─── Seller Wallet ────────────────────────────────────────────────────────────

model SellerWallet {
  id        String   @id @default(uuid())
  sellerId  String   @unique @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  transactions WalletTransaction[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("seller_wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  wallet      SellerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String   // RECHARGE | CAMPAIGN_PAYMENT | REFUND
  amount      Float    // positive = credit, negative = debit
  balanceAfter Float   @map("balance_after")
  description String
  reference   String?  // MonCash transaction ref or campaign id
  status      String   @default("COMPLETED") // PENDING | COMPLETED | FAILED
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Setting {
  key       String   @id
  value     String
  group     String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model HomepageBanner {
  id          String   @id @default(uuid())
  title       String?
  imageUrl    String   @map("image_url")
  targetUrl   String   @map("target_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("homepage_banners")
}

model FlashSaleItem {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([productId])
  @@map("flash_sale_items")
}

