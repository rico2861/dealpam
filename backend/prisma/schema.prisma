generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  SELLER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BusinessType {
  FOOD
  COSMETICS
  CLOTHING
  HOUSING
  VEHICLE
  SERVICES
  ELECTRONICS
  OTHER
}

enum SubscriptionTier {
  STARTER
  BUSINESS
  PREMIUM
  ELITE
}

enum ProductType {
  PHYSICAL
  SERVICE
  RENTAL
  VEHICLE
  FOOD
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MONCASH
  NATCASH
  STRIPE
  PAYPAL
  MANUAL
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  CONFIRMED
  RESOLVED
  RESOLVED_AGAINST_SELLER
  DISMISSED
}

enum ComplaintType {
  PRODUCT_QUALITY
  SELLER_BEHAVIOR
  FRAUD
  DELIVERY
  PAYMENT
  OTHER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  phone                String?   @unique
  passwordHash         String    @map("password_hash")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  avatar               String?
  role                 Role      @default(CUSTOMER)
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  isActive             Boolean   @default(true) @map("is_active")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")

  // Geo
  city                 String?
  department           String?  // Département haïtien (Nord, Ouest, Sud…)

  refreshTokens        RefreshToken[]
  addresses            Address[]
  orders               Order[]
  wishlistItems        WishlistItem[]
  cart                 Cart?
  reviews              Review[]
  complaints           Complaint[]
  notifications        Notification[]
  seller               Seller?
  auditLogs            AuditLog[]
  sentMessages         Message[]           @relation("MessageSender")
  conversations        ConversationUser[]

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@index([department])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           SellerStatus  @default(PENDING)
  businessType     BusinessType? @map("business_type")
  businessCity     String?       @map("business_city")
  businessDept     String?       @map("business_dept")
  businessAddress  String?       @map("business_address")
  nif              String?       @unique
  idDocumentUrl    String?       @map("id_document_url")
  businessDocUrl   String?       @map("business_doc_url")
  rejectionReason  String?       @map("rejection_reason")
  approvedBy       String?       @map("approved_by")
  approvedAt       DateTime?     @map("approved_at")
  store            Store?
  subscriptions    SellerSubscription[]
  documents        BusinessDocument[]
  adCampaigns      AdCampaign[]
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([businessDept])
  @@map("sellers")
}

model BusinessDocument {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type      String   // "ID", "BUSINESS_REGISTRATION", "TAX", "OTHER"
  url       String
  publicId  String   @map("public_id")
  fileName  String   @map("file_name")
  isValid   Boolean? @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@map("business_documents")
}

model Store {
  id           String    @id @default(uuid())
  sellerId     String    @unique @map("seller_id")
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String    @unique
  slug         String    @unique
  description  String?
  logoUrl      String?   @map("logo_url")
  bannerUrl    String?   @map("banner_url")
  address      String?
  city         String?
  department   String?
  phone        String?
  email        String?
  whatsapp     String?
  avgRating        Float     @default(0) @map("avg_rating")
  totalReviews     Int       @default(0) @map("total_reviews")
  totalSales       Int       @default(0) @map("total_sales")
  isVerified       Boolean   @default(false) @map("is_verified")
  isActive         Boolean   @default(true) @map("is_active")
  badges           String[]  @default([])
  reputationScore  Float     @default(100) @map("reputation_score")
  avgResponseTime  Int?      @map("avg_response_time") // minutes
  lastBadgeUpdate  DateTime? @map("last_badge_update")
  products     Product[]
  reviews      Review[]
  orders       Order[]
  appointments Appointment[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([department])
  @@map("stores")
}

model SubscriptionPlan {
  id                String           @id @default(uuid())
  tier              SubscriptionTier @unique
  name              String
  priceHTG          Decimal          @map("price_htg") @db.Decimal(10, 2)
  maxProducts       Int?             @map("max_products")
  maxImages         Int              @default(5) @map("max_images")
  hasVerifiedBadge  Boolean          @default(false) @map("has_verified_badge")
  hasEliteBadge     Boolean          @default(false) @map("has_elite_badge")
  hasPrioritySearch Boolean          @default(false) @map("has_priority_search")
  hasHomepageAd     Boolean          @default(false) @map("has_homepage_ad")
  hasAdvancedStats  Boolean          @default(false) @map("has_advanced_stats")
  hasAutoSponsored  Boolean          @default(false) @map("has_auto_sponsored")
  description       String?
  isActive          Boolean          @default(true) @map("is_active")
  subscriptions     SellerSubscription[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model SellerSubscription {
  id        String           @id @default(uuid())
  sellerId  String           @map("seller_id")
  seller    Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  planId    String           @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  isActive  Boolean          @default(true) @map("is_active")
  autoRenew Boolean          @default(true) @map("auto_renew")
  payment   Payment?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([isActive])
  @@index([endDate])
  @@map("seller_subscriptions")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  imageUrl  String?    @map("image_url")
  icon      String?
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("brands")
}

model Product {
  id              String      @id @default(uuid())
  storeId         String      @map("store_id")
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId      String      @map("category_id")
  category        Category    @relation(fields: [categoryId], references: [id])
  brandId         String?     @map("brand_id")
  brand           Brand?      @relation(fields: [brandId], references: [id])
  name            String
  slug            String      @unique
  description     String
  sku             String?     @unique
  productType     ProductType @default(PHYSICAL) @map("product_type")

  // Pricing
  price           Decimal     @db.Decimal(10, 2)
  salePrice       Decimal?    @map("sale_price") @db.Decimal(10, 2)
  stock           Int         @default(0)
  sizes           String[]
  colors          String[]

  // Geo / Delivery
  city            String?
  department      String?    // Département haïtien
  hasDelivery     Boolean    @default(false) @map("has_delivery")
  deliveryPriceHTG Decimal?  @map("delivery_price_htg") @db.Decimal(10, 2)
  deliveryDepts   String[]   @map("delivery_depts")  // List of departments where delivery is available

  // Vehicle / Rental specific
  year            Int?
  mileage         Int?
  condition       String?    // "new", "used", "refurbished"
  requiresAppointment Boolean @default(false) @map("requires_appointment")

  // Status & flags
  status          ProductStatus @default(DRAFT)
  isFeatured      Boolean   @default(false) @map("is_featured")
  isSponsored     Boolean   @default(false) @map("is_sponsored")
  avgRating       Float     @default(0) @map("avg_rating")
  totalReviews    Int       @default(0) @map("total_reviews")
  totalSold       Int       @default(0) @map("total_sold")
  viewCount       Int       @default(0) @map("view_count")
  rejectionReason String?   @map("rejection_reason")

  images          ProductImage[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  appointments    Appointment[]
  adCampaigns     AdCampaign[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([department])
  @@index([hasDelivery])
  @@index([productType])
  @@index([isFeatured])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  urlFull   String   @map("url_full")     // 800px WebP
  urlMedium String   @map("url_medium")   // 600px WebP
  urlThumb  String   @map("url_thumb")    // 300px WebP
  publicId  String   @map("public_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  size      String?
  color     String?

  @@unique([cartId, productId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  fullName   String   @map("full_name")
  phone      String
  line1      String
  city       String
  department String
  isDefault  Boolean  @default(false) @map("is_default")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addresses")
}

model Order {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  user           User        @relation(fields: [userId], references: [id])
  storeId        String      @map("store_id")
  store          Store       @relation(fields: [storeId], references: [id])
  addressId      String      @map("address_id")
  address        Address     @relation(fields: [addressId], references: [id])
  status         OrderStatus @default(PENDING)
  subtotalHTG    Decimal     @map("subtotal_htg") @db.Decimal(10, 2)
  shippingHTG    Decimal     @default(0) @map("shipping_htg") @db.Decimal(10, 2)
  totalHTG       Decimal     @map("total_htg") @db.Decimal(10, 2)
  notes          String?
  trackingNumber String?     @map("tracking_number")
  items          OrderItem[]
  payment        Payment?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name")
  imageUrl    String? @map("image_url")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model Payment {
  id             String              @id @default(uuid())
  orderId        String?             @unique @map("order_id")
  order          Order?              @relation(fields: [orderId], references: [id])
  subscriptionId String?             @unique @map("subscription_id")
  subscription   SellerSubscription? @relation(fields: [subscriptionId], references: [id])
  adCampaign     AdCampaign?
  method         PaymentMethod
  status         PaymentStatus       @default(PENDING)
  amountHTG      Decimal             @map("amount_htg") @db.Decimal(10, 2)
  transactionId  String?             @map("transaction_id")
  gatewayData    Json?               @map("gateway_data")
  paidAt         DateTime?           @map("paid_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  productId  String?  @map("product_id")
  product    Product? @relation(fields: [productId], references: [id])
  storeId    String?  @map("store_id")
  store      Store?   @relation(fields: [storeId], references: [id])
  rating     Int
  comment    String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model Complaint {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  type        ComplaintType
  status      ComplaintStatus @default(OPEN)
  subject     String
  description String
  orderId     String?         @map("order_id")
  sellerId    String?         @map("seller_id")
  productId   String?         @map("product_id")
  adminNote   String?         @map("admin_note")
  resolvedAt  DateTime?       @map("resolved_at")
  resolvedBy  String?         @map("resolved_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@map("complaints")
}

model Appointment {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  productId   String            @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  storeId     String            @map("store_id")
  store       Store             @relation(fields: [storeId], references: [id])
  status      AppointmentStatus @default(PENDING)
  scheduledAt DateTime          @map("scheduled_at")
  note        String?
  sellerNote  String?           @map("seller_note")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@map("appointments")
}

model Conversation {
  id           String             @id @default(uuid())
  participants ConversationUser[]
  messages     Message[]
  lastMessage  String?            @map("last_message")
  lastMessageAt DateTime?         @map("last_message_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("conversations")
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unreadCount    Int          @default(0) @map("unread_count")
  lastSeenAt     DateTime?    @map("last_seen_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_users")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String      @map("sender_id")
  sender         User        @relation("MessageSender", fields: [senderId], references: [id])
  type           MessageType @default(TEXT)
  content        String
  mediaUrl       String?     @map("media_url")
  isRead         Boolean     @default(false) @map("is_read")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Ad Campaign (Boost Produit — style Meta Ads) ─────────────────────────────

enum AdStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
  CANCELLED
}

enum AdObjective {
  AWARENESS      // Impressions max
  TRAFFIC        // Clics vers la fiche produit
  CONVERSIONS    // Achats
}

model AdCampaign {
  id             String      @id @default(uuid())
  sellerId       String      @map("seller_id")
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId      String      @map("product_id")
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Paramètres de la campagne
  name           String
  objective      AdObjective @default(TRAFFIC)
  status         AdStatus    @default(DRAFT)

  // Budget
  totalBudget    Decimal     @map("total_budget") @db.Decimal(10, 2)  // HTG total
  dailyBudget    Decimal?    @map("daily_budget") @db.Decimal(10, 2)
  spent          Decimal     @default(0) @db.Decimal(10, 2)           // HTG dépensé

  // Durée
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")

  // Ciblage
  targetGenders    String[]  @default([]) @map("target_genders")   // ["MALE","FEMALE","ALL"]
  targetAgeMin     Int?      @map("target_age_min")
  targetAgeMax     Int?      @map("target_age_max")
  targetDepts      String[]  @default([]) @map("target_depts")     // Départements haïtiens
  targetCategories String[]  @default([]) @map("target_categories")

  // Statistiques
  impressions    Int         @default(0)
  clicks         Int         @default(0)
  conversions    Int         @default(0)

  // Paiement
  paymentId      String?     @unique @map("payment_id")
  payment        Payment?    @relation(fields: [paymentId], references: [id])

  // Admin
  reviewNote     String?     @map("review_note")
  reviewedBy     String?     @map("reviewed_by")
  reviewedAt     DateTime?   @map("reviewed_at")

  events         AdEvent[]

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([productId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("ad_campaigns")
}

model AdEvent {
  id          String     @id @default(uuid())
  campaignId  String     @map("campaign_id")
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        String     // "IMPRESSION" | "CLICK" | "CONVERSION"
  userId      String?    @map("user_id")  // null = visiteur anonyme
  userDept    String?    @map("user_dept")
  cost        Decimal    @default(0) @db.Decimal(10, 2)  // HTG débité
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([campaignId])
  @@index([type])
  @@index([createdAt])
  @@map("ad_events")
}

model Setting {
  key       String   @id
  value     String
  group     String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
