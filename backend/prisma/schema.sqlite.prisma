// ═══════════════════════════════════════════════════════════════════════════
// SCHÉMA LOCAL SQLite — TEST UNIQUEMENT
// Usage : npm run dev:setup   (première fois — crée dev.db)
//         npm run dev         (lancer le serveur en mode watch)
//         npm run dev:studio  (Prisma Studio GUI)
// ═══════════════════════════════════════════════════════════════════════════
// Différences vs production PostgreSQL :
//   - Enums → String (SQLite ne supporte pas les enums natifs)
//   - String[] → String (JSON string, ex: '["MONCASH","CASH"]')
//   - @db.Decimal() → supprimé
//   - Json → String
//   - directUrl supprimé
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String?   @unique
  phone                String?   @unique
  passwordHash         String    @map("password_hash")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  avatar               String?
  role                 String    @default("CUSTOMER")
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  isActive             Boolean   @default(true) @map("is_active")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  lastLoginAt          DateTime? @map("last_login_at")
  lastLoginIp          String?   @map("last_login_ip")
  city                 String?
  department           String?

  refreshTokens   RefreshToken[]
  addresses       Address[]
  orders          Order[]
  wishlistItems   WishlistItem[]
  cart            Cart?
  reviews         Review[]
  complaints      Complaint[]
  notifications   Notification[]
  seller          Seller?
  auditLogs       AuditLog[]
  sentMessages    Message[]         @relation("MessageSender")
  conversations   ConversationUser[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           String    @default("PENDING")
  businessType     String?   @map("business_type")
  businessCity     String?   @map("business_city")
  businessDept     String?   @map("business_dept")
  businessAddress  String?   @map("business_address")
  nif              String?   @unique
  idDocumentUrl    String?   @map("id_document_url")
  businessDocUrl   String?   @map("business_doc_url")
  rejectionReason  String?   @map("rejection_reason")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")

  stores        Store[]
  subscriptions SellerSubscription[]
  documents     BusinessDocument[]
  adCampaigns   AdCampaign[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("sellers")
}

model BusinessDocument {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type      String
  url       String
  publicId  String   @map("public_id")
  fileName  String   @map("file_name")
  isValid   Boolean? @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@map("business_documents")
}

model Store {
  id          String  @id @default(uuid())
  sellerId    String  @map("seller_id")
  seller      Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String  @unique
  slug        String  @unique
  isPrimary   Boolean @default(false) @map("is_primary")
  description String?
  logoUrl     String? @map("logo_url")
  bannerUrl   String? @map("banner_url")
  address     String?
  city        String?
  department  String?
  phone       String?
  email       String?
  whatsapp    String?
  acceptedPaymentMethods String @default("[]") @map("accepted_payment_methods")
  moncashPhone           String? @map("moncash_phone")
  pickupPoints           String? @map("pickup_points")   // JSON: [{name,address,city,dept,phone,hours}]
  deliveryZones          String? @map("delivery_zones")  // JSON: [{dept,priceHTG,estimatedDays}]
  badges                 String @default("[]")
  avgRating       Float    @default(0) @map("avg_rating")
  totalReviews    Int      @default(0) @map("total_reviews")
  totalSales      Int      @default(0) @map("total_sales")
  isVerified      Boolean  @default(false) @map("is_verified")
  isActive        Boolean  @default(true) @map("is_active")
  reputationScore Float    @default(100) @map("reputation_score")
  avgResponseTime Int?     @map("avg_response_time")
  lastBadgeUpdate DateTime? @map("last_badge_update")

  products     Product[]
  reviews      Review[]
  orders       Order[]
  appointments Appointment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("stores")
}

model SubscriptionPlan {
  id                String  @id @default(uuid())
  tier              String  @unique
  name              String
  priceHTG          Decimal @map("price_htg")
  maxProducts       Int?    @map("max_products")
  maxImages         Int     @default(5) @map("max_images")
  maxStores         Int     @default(1) @map("max_stores")
  hasVerifiedBadge  Boolean @default(false) @map("has_verified_badge")
  hasEliteBadge     Boolean @default(false) @map("has_elite_badge")
  hasPrioritySearch Boolean @default(false) @map("has_priority_search")
  hasHomepageAd     Boolean @default(false) @map("has_homepage_ad")
  hasAdvancedStats  Boolean @default(false) @map("has_advanced_stats")
  hasAutoSponsored  Boolean @default(false) @map("has_auto_sponsored")
  description       String?
  isActive          Boolean @default(true) @map("is_active")
  subscriptions     SellerSubscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model SellerSubscription {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  planId    String   @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(true) @map("is_active")
  autoRenew Boolean  @default(true) @map("auto_renew")
  payment   Payment?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([isActive])
  @@map("seller_subscriptions")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  imageUrl  String?    @map("image_url")
  icon      String?
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("brands")
}

model Product {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String   @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id])
  brandId     String?  @map("brand_id")
  brand       Brand?   @relation(fields: [brandId], references: [id])
  name        String
  slug        String   @unique
  description String
  sku         String?  @unique
  productType String   @default("PHYSICAL") @map("product_type")

  price            Decimal
  salePrice        Decimal? @map("sale_price")
  stock            Int      @default(0)
  sizes            String   @default("[]")
  colors           String   @default("[]")
  city             String?
  department       String?
  hasDelivery      Boolean  @default(false) @map("has_delivery")
  deliveryPriceHTG Decimal? @map("delivery_price_htg")
  deliveryDepts    String   @default("[]") @map("delivery_depts")
  year             Int?
  mileage          Int?
  condition        String?
  requiresAppointment Boolean @default(false) @map("requires_appointment")

  status          String  @default("DRAFT")
  isFeatured      Boolean @default(false) @map("is_featured")
  isSponsored     Boolean @default(false) @map("is_sponsored")
  avgRating       Float   @default(0) @map("avg_rating")
  totalReviews    Int     @default(0) @map("total_reviews")
  totalSold       Int     @default(0) @map("total_sold")
  viewCount       Int     @default(0) @map("view_count")
  rejectionReason String? @map("rejection_reason")

  attributes    String?       @map("attributes") // JSON: category-specific fields

  images        ProductImage[]
  variants      ProductVariant[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]
  reviews       Review[]
  appointments  Appointment[]
  adCampaigns    AdCampaign[]
  flashSaleItems FlashSaleItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color         String?
  colorHex      String?  @map("color_hex")
  size          String?
  stock         Int      @default(0)
  priceOverride Decimal? @map("price_override")
  imageUrl      String?  @map("image_url")
  imagePublicId String?  @map("image_public_id")
  sku           String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  urlFull   String   @map("url_full")
  urlMedium String   @map("url_medium")
  urlThumb  String   @map("url_thumb")
  publicId  String   @map("public_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  size      String?
  color     String?

  @@unique([cartId, productId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  fullName   String   @map("full_name")
  phone      String
  line1      String
  city       String
  department String
  isDefault  Boolean  @default(false) @map("is_default")
  orders     Order[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addresses")
}

model Order {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id])
  storeId             String    @map("store_id")
  store               Store     @relation(fields: [storeId], references: [id])
  addressId           String?   @map("address_id")
  address             Address?  @relation(fields: [addressId], references: [id])
  status              String    @default("PENDING")
  subtotalHTG         Decimal   @map("subtotal_htg")
  shippingHTG         Decimal   @default(0) @map("shipping_htg")
  totalHTG            Decimal   @map("total_htg")
  notes               String?
  trackingNumber      String?   @map("tracking_number")
  deliveryType        String?   @default("DELIVERY") @map("delivery_type")
  pickupPointName     String?   @map("pickup_point_name")
  pickupPointAddress  String?   @map("pickup_point_address")
  chosenPaymentMethod String?   @map("chosen_payment_method")
  paymentTxRef        String?   @map("payment_tx_ref")
  paymentTxStatus     String?   @default("PENDING") @map("payment_tx_status")
  paymentTxNote       String?   @map("payment_tx_note")
  paymentVerifiedBy   String?   @map("payment_verified_by")
  paymentVerifiedAt   DateTime? @map("payment_verified_at")
  items               OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([paymentTxStatus])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name")
  imageUrl    String? @map("image_url")
  quantity    Int
  unitPrice   Decimal @map("unit_price")
  subtotal    Decimal

  @@map("order_items")
}

model Payment {
  id                   String    @id @default(uuid())
  subscriptionId       String?   @unique @map("subscription_id")
  subscription         SellerSubscription? @relation(fields: [subscriptionId], references: [id])
  adCampaign           AdCampaign?
  method               String
  status               String    @default("PENDING")
  amountHTG            Decimal   @map("amount_htg")
  transactionId        String?   @unique @map("transaction_id")
  moncashOrderId       String?   @unique @map("moncash_order_id")
  moncashTransactionId String?   @unique @map("moncash_transaction_id")
  gatewayData          String?   @map("gateway_data")
  paidAt               DateTime? @map("paid_at")
  failureReason        String?   @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  productId  String?  @map("product_id")
  product    Product? @relation(fields: [productId], references: [id])
  storeId    String?  @map("store_id")
  store      Store?   @relation(fields: [storeId], references: [id])
  rating     Int
  comment    String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model Complaint {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  type        String
  status      String    @default("OPEN")
  subject     String
  description String
  orderId     String?   @map("order_id")
  sellerId    String?   @map("seller_id")
  productId   String?   @map("product_id")
  adminNote   String?   @map("admin_note")
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?   @map("resolved_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("complaints")
}

model Appointment {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id])
  storeId     String   @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id])
  status      String   @default("PENDING")
  scheduledAt DateTime @map("scheduled_at")
  note        String?
  sellerNote  String?  @map("seller_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@map("appointments")
}

model Conversation {
  id            String             @id @default(uuid())
  participants  ConversationUser[]
  messages      Message[]
  lastMessage   String?            @map("last_message")
  lastMessageAt DateTime?          @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("conversations")
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unreadCount    Int          @default(0) @map("unread_count")
  lastSeenAt     DateTime?    @map("last_seen_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_users")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @map("sender_id")
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  type           String       @default("TEXT")
  content        String
  mediaUrl       String?      @map("media_url")
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValues String?  @map("old_values")
  newValues String?  @map("new_values")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

model AdCampaign {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  objective String   @default("TRAFFIC")
  status    String   @default("DRAFT")

  totalBudget      Decimal   @map("total_budget")
  dailyBudget      Decimal?  @map("daily_budget")
  spent            Decimal   @default(0)
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  targetGenders    String    @default("[]") @map("target_genders")
  targetAgeMin     Int?      @map("target_age_min")
  targetAgeMax     Int?      @map("target_age_max")
  targetDepts      String    @default("[]") @map("target_depts")
  targetCategories String    @default("[]") @map("target_categories")
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  conversions      Int       @default(0)
  paymentId        String?   @unique @map("payment_id")
  payment          Payment?  @relation(fields: [paymentId], references: [id])
  reviewNote       String?   @map("review_note")
  reviewedBy       String?   @map("reviewed_by")
  reviewedAt       DateTime? @map("reviewed_at")
  events           AdEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([status])
  @@map("ad_campaigns")
}

model AdEvent {
  id         String     @id @default(uuid())
  campaignId String     @map("campaign_id")
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       String
  userId     String?    @map("user_id")
  userDept   String?    @map("user_dept")
  cost       Decimal    @default(0)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([campaignId])
  @@map("ad_events")
}

model Setting {
  key       String   @id
  value     String
  group     String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model FlashSaleItem {
  id        String   @id @default(uuid())
  productId String   @map("product_id") @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("flash_sale_items")
}
