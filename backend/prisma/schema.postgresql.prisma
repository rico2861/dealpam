model TrendingCache {
  id        Int      @id @default(1)
  data      Json     @default("{}")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("trending_cache")
}

model MlModelState {
  id         Int      @id @default(1)
  stateJson  Json     @default("{}") @map("state_json")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@map("ml_model_state")
