generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  SELLER
  MODERATOR
  ADMIN
  SUPER_ADMIN
  PARTNER
  CUSTOMER_CARE
  ACCOUNTANT
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BusinessType {
  FOOD
  COSMETICS
  CLOTHING
  HOUSING
  VEHICLE
  SERVICES
  ELECTRONICS
  RESTAURANT
  CLINIC
  AGRICULTURE
  CONSTRUCTION
  EDUCATION
  TRANSPORT
  TECHNOLOGY
  EVENTS
  REAL_ESTATE
  BEAUTY
  ARTISANAT
  OTHER
}

enum SubscriptionTier {
  STARTER
  BUSINESS
  PREMIUM
  ELITE
}

enum ProductType {
  PHYSICAL
  SERVICE
  RENTAL
  VEHICLE
  FOOD
  REAL_ESTATE
  FREELANCE
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MONCASH
  NATCASH
  STRIPE
  PAYPAL
  MANUAL
  WALLET
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  CONFIRMED
  RESOLVED
  RESOLVED_AGAINST_SELLER
  DISMISSED
}

enum ComplaintType {
  PRODUCT_QUALITY
  SELLER_BEHAVIOR
  FRAUD
  DELIVERY
  PAYMENT
  OTHER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  BOT
  SYSTEM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String?   @unique
  phone                String?   @unique
  passwordHash         String    @map("password_hash")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  avatar               String?
  role                 Role      @default(CUSTOMER)
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  isActive             Boolean   @default(true) @map("is_active")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  lastLoginAt          DateTime? @map("last_login_at")
  lastLoginIp          String?   @map("last_login_ip")
  tokenVersion         Int       @default(0) @map("token_version")

  // Geo
  city                 String?
  department           String?

  // Away message (for sellers)
  awayMessageEnabled   Boolean   @default(false) @map("away_message_enabled")
  awayMessage          String?   @map("away_message")

  // E2E encryption
  publicKey            String?   @map("public_key")

  // Staff-specific metadata (JSON): { partnershipPercent, responsibilities, notes }
  staffMeta            String?   @map("staff_meta")

  refreshTokens        RefreshToken[]
  addresses            Address[]
  orders               Order[]
  wishlistItems        WishlistItem[]
  cart                 Cart?
  reviews              Review[]
  complaints           Complaint[]
  notifications        Notification[]
  seller               Seller?
  auditLogs            AuditLog[]
  sentMessages         Message[]           @relation("MessageSender")
  conversations        ConversationUser[]
  assignedConversations Conversation[]     @relation("ConvAssignedAgent")
  appointments          Appointment[]
  followedStores        StoreFollow[]

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([department])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  // Marqué au moment de la rotation (au lieu d'une suppression immédiate) pour
  // pouvoir détecter une réutilisation : un refresh token déjà consommé qui
  // revient signale un vol — toute la session de l'utilisateur est révoquée.
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           SellerStatus  @default(PENDING)
  businessType     BusinessType? @map("business_type")
  businessTypeOther String?      @map("business_type_other")
  businessCity     String?       @map("business_city")
  businessDept     String?       @map("business_dept")
  businessAddress  String?       @map("business_address")
  cin              String?       @map("cin")
  nif              String?       @unique
  idDocumentUrl    String?       @map("id_document_url")
  businessDocUrl   String?       @map("business_doc_url")
  rejectionReason  String?       @map("rejection_reason")
  approvedBy       String?       @map("approved_by")
  approvedAt       DateTime?     @map("approved_at")
  stores           Store[]
  subscriptions    SellerSubscription[]
  documents        BusinessDocument[]
  adCampaigns      AdCampaign[]
  wallet           SellerWallet?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([businessDept])
  @@map("sellers")
}

model BusinessDocument {
  id        String   @id @default(uuid())
  sellerId  String   @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type      String   // "ID", "BUSINESS_REGISTRATION", "TAX", "OTHER"
  url       String
  publicId  String   @map("public_id")
  fileName  String   @map("file_name")
  isValid   Boolean? @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@map("business_documents")
}

model Store {
  id           String    @id @default(uuid())
  storeCode    String?   @unique @map("store_code") // SHOP-XXXX
  sellerId     String    @map("seller_id")
  seller       Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String    @unique
  slug         String    @unique
  isPrimary    Boolean   @default(false) @map("is_primary")
  description  String?
  logoUrl      String?   @map("logo_url")
  bannerUrl    String?   @map("banner_url")
  address      String?
  city         String?
  department   String?
  phone        String?
  email        String?
  whatsapp     String?
  // Méthodes de paiement que le vendeur accepte (MONCASH, NATCASH, CASH, BANK_TRANSFER, OTHER) — stocké en JSON.stringify()
  acceptedPaymentMethods String @default("[]") @map("accepted_payment_methods")
  isPlatformStore  Boolean   @default(false) @map("is_platform_store")
  // Numéro MonCash du vendeur (pour que le client sache où payer)
  moncashPhone String?  @map("moncash_phone")
  // Points de retrait : [{name, address, city, dept, phone, hours}] — stocké en JSON.stringify()
  pickupPoints String?  @map("pickup_points")
  // Zones de livraison : [{dept, priceHTG, estimatedDays}] — stocké en JSON.stringify()
  deliveryZones String? @map("delivery_zones")
  // Devise d'affichage par défaut de la boutique : "HTG" ou "USD". Les prix
  // produits restent toujours stockés en HTG ; ce champ ne pilote que l'affichage.
  currency     String    @default("HTG")
  // Taux de change défini par le vendeur : nombre de HTG pour 1 USD (ex: 132.5).
  // Modifiable à tout moment — recalcule automatiquement les prix affichés.
  exchangeRate Decimal?  @map("exchange_rate") @db.Decimal(10, 4)
  avgRating        Float     @default(0) @map("avg_rating")
  totalReviews     Int       @default(0) @map("total_reviews")
  totalSales       Int       @default(0) @map("total_sales")
  isVerified       Boolean   @default(false) @map("is_verified")
  hasVerifiedPatente Boolean @default(false) @map("has_verified_patente")
  isActive         Boolean   @default(true) @map("is_active")
  badges           String[]  @default([])
  reputationScore  Float     @default(100) @map("reputation_score")
  avgResponseTime  Int?      @map("avg_response_time") // minutes
  lastBadgeUpdate  DateTime? @map("last_badge_update")
  // Booste par une campagne pub "boutique" active tant que cette date est dans le futur —
  // s'auto-expire sans cron : les requêtes de classement vérifient juste adBoostedUntil > now.
  adBoostedUntil   DateTime? @map("ad_boosted_until")
  // Nombre de clients abonnés à cette boutique (StoreFollow) — dénormalisé pour
  // affichage rapide, tenu à jour par storesService.follow()/unfollow().
  followersCount   Int       @default(0) @map("followers_count")
  products     Product[]
  reviews      Review[]
  orders       Order[]
  appointments Appointment[]
  adCampaigns  AdCampaign[]
  followers    StoreFollow[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([storeCode])
  @@index([department])
  @@index([adBoostedUntil])
  @@map("stores")
}

// Abonnement d'un client à une boutique (pas à confondre avec SellerSubscription,
// qui est l'abonnement payant du VENDEUR à un plan DealPam). Sert à notifier le
// client des nouveautés de cette boutique et à afficher un compteur d'abonnés.
model StoreFollow {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String   @map("store_id")
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, storeId])
  @@index([storeId])
  @@map("store_follows")
}

model SubscriptionPlan {
  id                String           @id @default(uuid())
  tier              SubscriptionTier @unique
  name              String
  priceHTG          Decimal          @map("price_htg") @db.Decimal(10, 2)
  maxProducts       Int?             @map("max_products")
  // Quota séparé pour les produits de type SERVICE — null = illimité, 0 = non autorisé
  maxServices       Int?             @map("max_services")
  maxImages         Int              @default(5) @map("max_images")
  maxStores         Int              @default(1) @map("max_stores")
  hasVerifiedBadge  Boolean          @default(false) @map("has_verified_badge")
  hasEliteBadge     Boolean          @default(false) @map("has_elite_badge")
  hasPrioritySearch Boolean          @default(false) @map("has_priority_search")
  hasHomepageAd     Boolean          @default(false) @map("has_homepage_ad")
  hasAdvancedStats  Boolean          @default(false) @map("has_advanced_stats")
  hasAutoSponsored  Boolean          @default(false) @map("has_auto_sponsored")
  hasKeywordTargeting Boolean        @default(false) @map("has_keyword_targeting")
  description       String?
  isActive          Boolean          @default(true) @map("is_active")
  // Mis en avant "POPULAIRE" — pilotable depuis l'admin (un seul plan à la fois en pratique)
  isPopular         Boolean          @default(false) @map("is_popular")
  // Prix "barré" affiché avant le prix réel, pour créer un effet d'ancrage (optionnel)
  originalPriceHTG  Decimal?         @map("original_price_htg") @db.Decimal(10, 2)
  // Produits que le vendeur peut publier comme pub (jamais dans le carousel homepage)
  maxPromoProducts    Int            @default(0) @map("max_promo_products")
  // Sous-ensemble des produits pub qui peuvent aussi apparaître dans le carousel homepage
  maxCarouselProducts Int            @default(0) @map("max_carousel_products")
  // % de réduction si le vendeur paie pour 1 an d'un coup (configurable par l'admin)
  annualDiscountPercent Int          @default(25) @map("annual_discount_percent")
  subscriptions     SellerSubscription[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model SellerSubscription {
  id        String           @id @default(uuid())
  sellerId  String           @map("seller_id")
  seller    Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  planId    String           @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  isActive  Boolean          @default(true) @map("is_active")
  autoRenew Boolean          @default(true) @map("auto_renew")
  billingCycle String        @default("MONTHLY") @map("billing_cycle") // MONTHLY | ANNUAL
  isTrial   Boolean          @default(false) @map("is_trial")
  // Le vendeur a demandé l'annulation : reste actif jusqu'à endDate, puis n'est pas renouvelé.
  cancelAtPeriodEnd Boolean  @default(false) @map("cancel_at_period_end")
  payment   Payment?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([isActive])
  @@index([endDate])
  @@map("seller_subscriptions")
}

model TrialUsage {
  id       String   @id @default(uuid())
  sellerId String   @map("seller_id")
  phone    String?
  email    String?
  nif      String?
  usedAt   DateTime @default(now()) @map("used_at")

  @@index([phone])
  @@index([email])
  @@index([nif])
  @@map("trial_usages")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  imageUrl  String?    @map("image_url")
  icon      String?
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("brands")
}

model Product {
  id              String      @id @default(uuid())
  storeId         String      @map("store_id")
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId      String      @map("category_id")
  category        Category    @relation(fields: [categoryId], references: [id])
  brandId         String?     @map("brand_id")
  brand           Brand?      @relation(fields: [brandId], references: [id])
  name            String
  slug            String      @unique
  subtitle        String?     @db.VarChar(80)
  description     String
  sku             String?     @unique
  productType     ProductType @default(PHYSICAL) @map("product_type")

  // Pricing
  price           Decimal     @db.Decimal(10, 2)
  salePrice       Decimal?    @map("sale_price") @db.Decimal(10, 2)
  stock           Int         @default(0)
  sizes           String[]
  colors          String[]
  // Prix dégressifs par palier de quantité — ex: [{"minQty":1,"price":500},{"minQty":3,"price":650},{"minQty":12,"price":2345}]
  // stocké en JSON.stringify(), trié par minQty croissant. Le prix appliqué est
  // celui du plus grand palier dont minQty <= quantité commandée (jamais < 1er palier).
  priceTiers      String?     @map("price_tiers")
  // Quantité minimale de commande imposée par le vendeur sur ce produit (défaut 1).
  minOrderQty     Int         @default(1) @map("min_order_qty")
  // Le client peut proposer son propre prix (négociation) au lieu du prix catalogue.
  allowOffers     Boolean     @default(false) @map("allow_offers")
  minOfferPriceHTG Decimal?   @map("min_offer_price_htg") @db.Decimal(10, 2)

  // Geo / Delivery
  address         String?                 // Full address (for services/RE)
  city            String?
  department      String?    // Département haïtien
  hasDelivery     Boolean    @default(false) @map("has_delivery")
  deliveryPriceHTG Decimal?  @map("delivery_price_htg") @db.Decimal(10, 2)
  deliveryDepts   String[]   @map("delivery_depts")  // List of departments where delivery is available
  // Sous-ensemble des points de retrait de la boutique (Store.pickupPoints) où ce
  // produit est disponible, stocké en JSON.stringify(string[]) (les `name` des
  // points sélectionnés). null ou "[]" = aucune restriction => disponible à TOUS
  // les points de retrait de la boutique (comportement par défaut, pour ne pas
  // casser les produits existants qui n'ont jamais eu ce champ).
  pickupPointNames String?   @map("pickup_point_names")

  // Vehicle / Rental specific
  year            Int?
  mileage         Int?
  condition       String?    // "new", "used", "refurbished"
  requiresAppointment Boolean @default(false) @map("requires_appointment")

  // Status & flags
  status          ProductStatus @default(DRAFT)
  isFeatured      Boolean   @default(false) @map("is_featured")
  isSponsored     Boolean   @default(false) @map("is_sponsored")
  // Booste par une campagne pub active tant que cette date est dans le futur — s'auto-expire
  // sans intervention de cron : les requêtes de classement vérifient juste adBoostedUntil > now.
  adBoostedUntil  DateTime? @map("ad_boosted_until")
  avgRating       Float     @default(0) @map("avg_rating")
  totalReviews    Int       @default(0) @map("total_reviews")
  totalSold       Int       @default(0) @map("total_sold")
  viewCount       Int       @default(0) @map("view_count")
  rejectionReason String?   @map("rejection_reason")
  // Détection automatique de mots-clés interdits (armes, drogues, contrefaçon…)
  // à la publication — ne bloque jamais seul, force juste une revue admin.
  isFlagged       Boolean   @default(false) @map("is_flagged")
  flagReason      String?   @map("flag_reason")

  // Modification d'un produit déjà PUBLISHED : la version en ligne reste
  // visible telle quelle pendant la validation — les changements proposés
  // sont stockés ici (JSON.stringify()) et appliqués seulement à l'approbation.
  hasPendingEdit         Boolean  @default(false) @map("has_pending_edit")
  pendingChanges         String?  @map("pending_changes")
  pendingRejectionReason String?  @map("pending_rejection_reason")

  // Category-specific attributes stored as JSON (phone: brand/model/storage/ram; clothing: material/gender; etc.) — stocké en JSON.stringify()
  attributes      String?       @map("attributes")
  // Service / Immobilier / Freelance extra config (JSON) — stocké en JSON.stringify()
  serviceConfig   String?       @map("service_config")
  // Price unit label: "HTG/heure", "HTG/séance", "HTG/m²", "HTG/projet", "HTG/nuit"
  priceUnit       String?       @map("price_unit")

  images          ProductImage[]
  variants        ProductVariant[]
  priceHistory    PriceHistory[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  appointments    Appointment[]
  adCampaigns     AdCampaign[]
  flashSaleItems  FlashSaleItem[]
  viewLogs        ProductView[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([department])
  @@index([hasDelivery])
  @@index([productType])
  @@index([isFeatured])
  @@index([adBoostedUntil])
  // Combinaisons réellement filtrées ensemble dans products.service.ts —
  // un index composite évite un scan supplémentaire par rapport à deux index
  // simples croisés.
  @@index([storeId, status])
  @@index([storeId, productType, status])
  @@index([categoryId, status])
  @@map("products")
}

// Journal des vues produit — sert UNIQUEMENT à dédupliquer Product.viewCount
// (ne pas recompter la même session dans une courte fenêtre, voir
// products.service.ts). viewerKey = id anonyme généré côté client (localStorage)
// pour les visiteurs non connectés, ou userId pour les visiteurs connectés.
model ProductView {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewerKey String   @map("viewer_key")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId, viewerKey, createdAt])
  @@map("product_views")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  urlFull   String   @map("url_full")     // 800px WebP
  urlMedium String   @map("url_medium")   // 600px WebP
  urlThumb  String   @map("url_thumb")    // 300px WebP
  publicId  String   @map("public_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color         String?
  colorHex      String?  @map("color_hex")
  size          String?
  stock         Int      @default(0)
  priceOverride Decimal? @map("price_override") @db.Decimal(10, 2)
  imageUrl      String?  @map("image_url")
  imagePublicId String?  @map("image_public_id")
  sku           String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_variants")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String  @map("cart_id")
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  size      String?
  color     String?
  // Prix négocié propose par le client (feature "faire une offre") — force quantity=1.
  offeredPrice Decimal? @map("offered_price") @db.Decimal(10, 2)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  addedAt   DateTime @default(now()) @map("added_at")

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  fullName   String   @map("full_name")
  phone      String
  line1      String
  city       String
  department String
  isDefault  Boolean  @default(false) @map("is_default")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("addresses")
}

model Order {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  user           User        @relation(fields: [userId], references: [id])
  storeId        String      @map("store_id")
  store          Store       @relation(fields: [storeId], references: [id])
  addressId      String?     @map("address_id")
  address        Address?    @relation(fields: [addressId], references: [id])
  status         OrderStatus @default(PENDING)
  subtotalHTG    Decimal     @map("subtotal_htg") @db.Decimal(10, 2)
  shippingHTG    Decimal     @default(0) @map("shipping_htg") @db.Decimal(10, 2)
  totalHTG       Decimal     @map("total_htg") @db.Decimal(10, 2)
  notes                String?
  trackingNumber       String?  @map("tracking_number")
  // Livraison : DELIVERY (adresse) | PICKUP (retrait boutique) | CONTACT (direct contact)
  deliveryType         String?  @default("DELIVERY") @map("delivery_type")
  pickupPointName      String?  @map("pickup_point_name")
  pickupPointAddress   String?  @map("pickup_point_address")
  // Méthode de paiement choisie par le client (parmi celles du vendeur)
  chosenPaymentMethod  String?  @map("chosen_payment_method")
  // Référence de transaction soumise par le client (MonCash/NatCash txId)
  paymentTxRef         String?  @map("payment_tx_ref")
  paymentTxStatus      String?  @default("PENDING") @map("payment_tx_status")
  paymentTxNote        String?  @map("payment_tx_note")
  paymentVerifiedBy    String?  @map("payment_verified_by")
  paymentVerifiedAt    DateTime? @map("payment_verified_at")
  // Motif d'annulation (manuel par le vendeur, ou automatique via le cron de commandes bloquées).
  cancelReason         String?  @map("cancel_reason")
  // Anti-double-envoi de la relance vendeur (cron 48h) — non-null = relance déjà envoyée.
  reminderSentAt       DateTime? @map("reminder_sent_at")
  items          OrderItem[]
  reviews        Review[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([paymentTxStatus])
  @@index([storeId, status])
  @@index([userId, status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  productName String  @map("product_name")
  imageUrl    String? @map("image_url")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  // Negociation de prix ("faire une offre") — offeredPrice = prix propose par le
  // client (deja copie dans unitPrice si accepte). offerStatus: PENDING/ACCEPTED/
  // REJECTED/COUNTERED/DECLINED, null = item normal. counterPrice = dernier prix
  // propose par le vendeur quand offerStatus = COUNTERED (le client accepte ou
  // decline ce prix ensuite — voir OrdersService.decideOffer/respondToCounter).
  offeredPrice         Decimal? @map("offered_price") @db.Decimal(10, 2)
  offerStatus          String?  @map("offer_status")
  offerRejectionReason String?  @map("offer_rejection_reason")
  counterPrice         Decimal? @map("counter_price") @db.Decimal(10, 2)

  @@map("order_items")
}

model Payment {
  id             String              @id @default(uuid())
  // Payments = vendeurs seulement (abonnements + pub). Pas de paiement client sur plateforme.
  subscriptionId String?             @unique @map("subscription_id")
  subscription   SellerSubscription? @relation(fields: [subscriptionId], references: [id])
  adCampaign     AdCampaign?
  couponId          String?  @map("coupon_id")
  couponDiscountHTG Decimal? @map("coupon_discount_htg") @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus       @default(PENDING)
  amountHTG            Decimal             @map("amount_htg") @db.Decimal(10, 2)

  // Référence interne plateforme (UUID envoyé à MonCash comme orderId)
  transactionId        String?             @unique @map("transaction_id")
  // moncash_order_id retourné par l'API MonCash lors de l'initiation
  moncashOrderId       String?             @unique @map("moncash_order_id")
  // transaction_id final confirmé par MonCash (webhook / confirm endpoint)
  moncashTransactionId String?             @unique @map("moncash_transaction_id")

  gatewayData          Json?               @map("gateway_data")
  paidAt               DateTime?           @map("paid_at")
  failureReason        String?             @map("failure_reason")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([moncashOrderId])
  @@index([status])
  @@map("payments")
}

enum MoncashTxStatus {
  SUCCESS
  FAILED
  ALREADY_CREDITED
  PENDING
  UNKNOWN
}

// Journal exhaustif de chaque vérification MonCash effectuée (succès ou échec),
// tous scénarios confondus (wallet, abonnement, campagne pub). Sert à la fois
// de verrou anti-double-crédit et de piste d'audit pour la page admin.
model MoncashTransaction {
  id                   String          @id @default(uuid())
  orderId              String?         @map("order_id")
  moncashTransactionId String?         @unique @map("moncash_transaction_id")
  reference            String?
  amount               Decimal?        @db.Decimal(10, 2)
  payer                String?
  status               MoncashTxStatus @default(PENDING)
  failReason           String?         @map("fail_reason")
  credited             Boolean         @default(false)
  scenario             String
  rawResponse          Json?           @map("raw_response")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([status])
  @@index([scenario])
  @@map("moncash_transactions")
}

model Review {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  productId  String?  @map("product_id")
  product    Product? @relation(fields: [productId], references: [id])
  storeId    String?  @map("store_id")
  store      Store?   @relation(fields: [storeId], references: [id])
  orderId    String?  @map("order_id")
  order      Order?   @relation(fields: [orderId], references: [id])
  rating     Int
  comment    String?
  images     String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  // Un client ne peut laisser qu'un seul avis par boutique (les lignes avec
  // storeId NULL — avis produit sans boutique — ne sont pas concernées par
  // cette contrainte : NULL n'est jamais égal à NULL en SQL).
  @@unique([userId, storeId])
  @@map("reviews")
}

model Complaint {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  type        ComplaintType
  status      ComplaintStatus @default(OPEN)
  subject     String
  description String
  orderId     String?         @map("order_id")
  sellerId    String?         @map("seller_id")
  productId   String?         @map("product_id")
  adminNote   String?         @map("admin_note")
  resolvedAt  DateTime?       @map("resolved_at")
  resolvedBy  String?         @map("resolved_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@map("complaints")
}

model Appointment {
  id          String            @id @default(uuid())
  userId      String?           @map("user_id")   // null for guest bookings
  user        User?             @relation(fields: [userId], references: [id])
  productId   String            @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  storeId     String            @map("store_id")
  store       Store             @relation(fields: [storeId], references: [id])
  status      AppointmentStatus @default(PENDING)
  scheduledAt DateTime          @map("scheduled_at")
  note        String?
  sellerNote  String?           @map("seller_note")
  // Guest booking info (client non connecté)
  clientName  String?           @map("client_name")
  clientPhone String?           @map("client_phone")
  clientEmail String?           @map("client_email")
  // Service sub-type (ex: "Coupe femme", "Détartrage", "Logo design")
  serviceType String?           @map("service_type")
  // Duration in minutes
  duration    Int?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@map("appointments")
}

model Conversation {
  id              String             @id @default(uuid())
  participants    ConversationUser[]
  messages        Message[]
  lastMessage     String?            @map("last_message")
  lastMessageAt   DateTime?          @map("last_message_at")
  isSupport       Boolean            @default(false) @map("is_support")
  topic           String?
  status          String             @default("OPEN")  // OPEN | RESOLVED | CLOSED
  ticketNumber    String?            @unique @map("ticket_number")
  assignedAgentId String?            @map("assigned_agent_id")
  assignedAgent   User?              @relation("ConvAssignedAgent", fields: [assignedAgentId], references: [id])
  closedAt        DateTime?          @map("closed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([isSupport])
  @@index([status])
  @@map("conversations")
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unreadCount    Int          @default(0) @map("unread_count")
  lastSeenAt     DateTime?    @map("last_seen_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_users")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String      @map("sender_id")
  sender         User        @relation("MessageSender", fields: [senderId], references: [id])
  type           MessageType @default(TEXT)
  content        String
  mediaUrl       String?     @map("media_url")
  isRead         Boolean     @default(false) @map("is_read")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

model PriceHistory {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @map("sale_price") @db.Decimal(10, 2)
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([productId, recordedAt])
  @@map("price_history")
}

model UserEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  sessionId   String   @map("session_id")
  eventType   String   @map("event_type") // VIEW, LIKE, UNLIKE, SEARCH, CLICK, ADD_CART, PURCHASE
  productId   String?  @map("product_id")
  categorySlug String? @map("category_slug")
  searchQuery String?  @map("search_query")
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType, createdAt])
  @@map("user_events")
}

// ─── Ad Campaign (Boost Produit — style Meta Ads) ─────────────────────────────

enum AdStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
  CANCELLED
}

enum AdObjective {
  AWARENESS      // Impressions max
  TRAFFIC        // Clics vers la fiche produit
  CONVERSIONS    // Achats
}

model AdCampaign {
  id             String      @id @default(uuid())
  sellerId       String      @map("seller_id")
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId      String?     @map("product_id")
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  storeId        String?     @map("store_id")
  store          Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)

  // Paramètres de la campagne
  name           String
  objective      AdObjective @default(TRAFFIC)
  status         AdStatus    @default(DRAFT)

  // Budget
  totalBudget    Decimal     @map("total_budget") @db.Decimal(10, 2)  // HTG total
  dailyBudget    Decimal?    @map("daily_budget") @db.Decimal(10, 2)
  spent          Decimal     @default(0) @db.Decimal(10, 2)           // HTG dépensé

  // Durée
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  // Instant choisi par le vendeur pour démarrer réellement la diffusion — null = approuvée
  // mais pas encore publiée manuellement. Non-null = campagne "live" à partir de cette date.
  publishedAt    DateTime?   @map("published_at")
  // Dernier jour calendaire (granularité date, pas heure) où cette campagne a été débitée
  // par le cron de facturation quotidienne — empêche un double-débit si le cron tourne deux fois le même jour.
  lastBilledDate DateTime?   @map("last_billed_date")

  // Ciblage
  targetGenders    String[]  @default([]) @map("target_genders")   // ["MALE","FEMALE","ALL"]
  targetAgeMin     Int?      @map("target_age_min")
  targetAgeMax     Int?      @map("target_age_max")
  targetDepts      String[]  @default([]) @map("target_depts")     // Départements haïtiens
  targetCategories String[]  @default([]) @map("target_categories")
  // Centres d'intérêt sélectionnés manuellement par le vendeur (liste fixe côté
  // frontend, ex. "Mode", "Technologie"...) — PAS un ciblage inféré par
  // comportement/ML, une simple liste de tags choisis à la main.
  targetInterests  String[]  @default([]) @map("target_interests")

  // Statistiques
  impressions    Int         @default(0)
  clicks         Int         @default(0)
  conversions    Int         @default(0)

  // Paiement
  paymentId      String?     @unique @map("payment_id")
  payment        Payment?    @relation(fields: [paymentId], references: [id])

  // Admin
  reviewNote     String?     @map("review_note")
  reviewedBy     String?     @map("reviewed_by")
  reviewedAt     DateTime?   @map("reviewed_at")

  events         AdEvent[]

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([productId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("ad_campaigns")
}

// Réglages de tarification publicitaire, éditables depuis le panneau admin
// (au lieu de constantes codées en dur dans ads.service.ts). Une seule ligne
// utilisée en pratique (id fixe 'default') — pas besoin de multi-tenant ici.
model AdSettings {
  id           String  @id @default("default")
  minBudgetHTG Decimal @default(250) @map("min_budget_htg") @db.Decimal(10, 2)
  cpmRateHTG   Decimal @default(150) @map("cpm_rate_htg") @db.Decimal(10, 2)   // HTG pour 1 000 impressions
  cpcRateHTG   Decimal @default(25)  @map("cpc_rate_htg") @db.Decimal(10, 2)   // HTG par clic

  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ad_settings")
}

model AdEvent {
  id          String     @id @default(uuid())
  campaignId  String     @map("campaign_id")
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        String     // "IMPRESSION" | "CLICK" | "CONVERSION"
  userId      String?    @map("user_id")  // null = visiteur anonyme
  userDept    String?    @map("user_dept")
  cost        Decimal    @default(0) @db.Decimal(10, 2)  // HTG débité
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([campaignId])
  @@index([type])
  @@index([createdAt])
  @@map("ad_events")
}

model Setting {
  key       String   @id
  value     String
  group     String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model SellerWallet {
  id        String   @id @default(uuid())
  sellerId  String   @unique @map("seller_id")
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  transactions WalletTransaction[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("seller_wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  wallet      SellerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String   // RECHARGE | CAMPAIGN_PAYMENT | REFUND
  amount      Float    // positive = credit, negative = debit
  balanceAfter Float   @map("balance_after")
  description String
  reference   String?  // MonCash transaction ref or campaign id
  status      String   @default("COMPLETED") // PENDING | COMPLETED | FAILED
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  token       String   @unique
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@map("newsletter_subscribers")
}

model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  description     String?
  discountType    String    @map("discount_type") // PERCENTAGE | FIXED_AMOUNT
  discountValue   Decimal   @map("discount_value") @db.Decimal(10, 2)
  // Où le coupon est utilisable : SUBSCRIPTION | PLATFORM_PRODUCT | BOTH
  appliesTo       String    @default("BOTH") @map("applies_to")
  minAmountHTG    Decimal?  @map("min_amount_htg") @db.Decimal(10, 2)
  maxDiscountHTG  Decimal?  @map("max_discount_htg") @db.Decimal(10, 2)
  maxUses         Int?      @map("max_uses") // null = illimité
  usedCount       Int       @default(0) @map("used_count")
  maxUsesPerUser  Int       @default(1) @map("max_uses_per_user")
  startsAt        DateTime? @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  isActive        Boolean   @default(true) @map("is_active")
  redemptions     CouponRedemption[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponRedemption {
  id                String   @id @default(uuid())
  couponId          String   @map("coupon_id")
  coupon            Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId            String   @map("user_id")
  context           String   // SUBSCRIPTION | PLATFORM_PRODUCT
  referenceId       String?  @map("reference_id") // subscriptionId ou orderId
  amountDiscounted  Decimal  @map("amount_discounted") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model HomepageBanner {
  id          String   @id @default(uuid())
  tag         String?  // ex: "MODE & STYLE", badge affiché au-dessus du titre
  title       String?
  subtitle    String?  // texte descriptif sous le titre
  ctaText     String?  @map("cta_text") // texte du bouton, ex: "Découvrir"
  catFilter   String?  @map("cat_filter") // slug catégorie utilisé pour filtrer les produits du mini-carousel
  imageUrl    String   @map("image_url")
  targetUrl   String   @map("target_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("homepage_banners")
}

model FlashSaleItem {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([productId])
  @@map("flash_sale_items")
}

