# ── Supabase / PostgreSQL ─────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="change_this_super_secret_jwt_key_32chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_32chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://dealpam.com"
ADMIN_URL="https://admin.dealpam.com"

# ── Cloudflare R2 (images & documents) ───────────────────
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key_id"
R2_SECRET_ACCESS_KEY="your_secret_access_key"
R2_BUCKET_NAME="dealpam"
R2_ENDPOINT="https://your_account_id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ── Email (SMTP Hostinger — 3 comptes, 1 par type de destinataire) ─────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=587
SMTP_SECURE=false
# Client (confirmations commande, reset password, notifications diverses)
SMTP_SUPPORT_USER="support@dealpam.com"
SMTP_SUPPORT_PASS="your_support_password"
# Vendeur (nouvelle commande, stock, paiement)
SMTP_SELLERS_USER="sellers@dealpam.com"
SMTP_SELLERS_PASS="your_sellers_password"
# Équipe interne (alertes, litiges, rapports, notifications système)
SMTP_TEAM_USER="team@dealpam.com"
SMTP_TEAM_PASS="your_team_password"

# ── MonCash (Digicel) ─────────────────────────────────────
MONCASH_CLIENT_ID="your_moncash_client_id"
MONCASH_SECRET_KEY="your_moncash_secret"
MONCASH_MODE="sandbox"

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
