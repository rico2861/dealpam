# ── Supabase / PostgreSQL ─────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="change_this_super_secret_jwt_key_32chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_32chars"
# Comptes client/vendeur
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="30d"
# Comptes d'équipe (ADMIN/SUPER_ADMIN/MODERATOR/...) — session plus courte,
# invisible pour l'utilisateur grâce au rafraîchissement silencieux côté front.
JWT_ADMIN_EXPIRES_IN="1h"
JWT_ADMIN_REFRESH_EXPIRES_IN="1d"

# ── App ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://dealpam.com"
ADMIN_URL="https://admin.dealpam.com"

# ── Cloudflare R2 (images & documents) ───────────────────
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key_id"
R2_SECRET_ACCESS_KEY="your_secret_access_key"
R2_BUCKET_NAME="dealpam"
R2_ENDPOINT="https://your_account_id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ── Email (Resend — API HTTPS, domaine dealpam.com verifie) ─────────────────
# Le SMTP direct vers Hostinger timeoutait systematiquement depuis Render
# (port 465/587 bloque cote reseau) — remplace par Resend (port 443, jamais
# bloque). Un seul compte API, 3 adresses "from" differentes selon le type
# de destinataire.
RESEND_API_KEY="re_your_api_key"
# Client (confirmations commande, reset password, notifications diverses)
MAIL_FROM_CLIENT="support@dealpam.com"
# Vendeur (nouvelle commande, stock, paiement)
MAIL_FROM_SELLER="sellers@dealpam.com"
# Équipe interne (alertes, litiges, rapports, notifications système)
MAIL_FROM_ADMIN="team@dealpam.com"

# ── MonCash (Digicel) ─────────────────────────────────────
MONCASH_CLIENT_ID="your_moncash_client_id"
MONCASH_SECRET_KEY="your_moncash_secret"
MONCASH_MODE="sandbox"

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
